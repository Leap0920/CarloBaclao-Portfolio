'use client';

import { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { ChevronLeft, ChevronRight } from 'lucide-react';

export function SwipeHint() {
  const [visible, setVisible] = useState(false);

  useEffect(() => {
    // Only show on mobile, and only once per session
    const isMobile = window.innerWidth < 768;
    const seen = sessionStorage.getItem('swipe-hint-seen');
    if (isMobile && !seen) {
      const timer = setTimeout(() => setVisible(true), 1500);
      return () => clearTimeout(timer);
    }
  }, []);

  useEffect(() => {
    if (!visible) return;
    const timer = setTimeout(() => {
      setVisible(false);
      sessionStorage.setItem('swipe-hint-seen', '1');
    }, 4000);
    return () => clearTimeout(timer);
  }, [visible]);

  // Hide when user touches
  useEffect(() => {
    if (!visible) return;
    const hide = () => {
      setVisible(false);
      sessionStorage.setItem('swipe-hint-seen', '1');
    };
    window.addEventListener('touchstart', hide, { once: true });
    return () => window.removeEventListener('touchstart', hide);
  }, [visible]);

  return (
    <AnimatePresence>
      {visible && (
        <>
          {/* Left hint */}
          <motion.div
            initial={{ opacity: 0, x: -20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            transition={{ duration: 0.4 }}
            className="md:hidden fixed left-1 top-1/2 -translate-y-1/2 z-30 flex items-center gap-1"
          >
            <motion.div
              animate={{ x: [-4, 4, -4] }}
              transition={{ duration: 1.5, repeat: Infinity, ease: 'easeInOut' }}
              className="flex items-center gap-0.5 bg-white/10 dark:bg-slate-800/60 backdrop-blur-md rounded-full px-2 py-1.5 border border-white/10"
            >
              <ChevronLeft size={12} className="text-orange-400" />
              <span className="text-[8px] text-white/60 font-medium tracking-wider">MENU</span>
            </motion.div>
          </motion.div>

          {/* Right hint */}
          <motion.div
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: 20 }}
            transition={{ duration: 0.4, delay: 0.15 }}
            className="md:hidden fixed right-1 top-1/2 -translate-y-1/2 z-30 flex items-center gap-1"
          >
            <motion.div
              animate={{ x: [4, -4, 4] }}
              transition={{ duration: 1.5, repeat: Infinity, ease: 'easeInOut' }}
              className="flex items-center gap-0.5 bg-white/10 dark:bg-slate-800/60 backdrop-blur-md rounded-full px-2 py-1.5 border border-white/10"
            >
              <span className="text-[8px] text-white/60 font-medium tracking-wider">SKILLS</span>
              <ChevronRight size={12} className="text-orange-400" />
            </motion.div>
          </motion.div>
        </>
      )}
    </AnimatePresence>
  );
}
